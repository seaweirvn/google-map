# Google Maps 抓取配置
HEADLESS=false
BROWSER_CHANNEL=
USER_DATA_DIR=chrome-profile-stable
SLOW_MO_MS=150
MAX_RESULTS_PER_QUERY=0
SCRAPE_LIMIT=0
MAX_SCROLL_ROUNDS=120
PAUSE_EVERY_SHOPS=20
PAUSE_MS=60000
MIN_WAIT_MS=3000
MAX_WAIT_MS=8000
NAVIGATION_TIMEOUT_MS=60000
DETAIL_TIMEOUT_MS=20000

# 可选代理，格式：host:port:username:password
# 用户名里可以使用 {session}，程序启动时会自动替换为随机数。
PROXY_URL=

# 输出路径
OUTPUT_CSV=output/shops.csv
PROGRESS_FILE=data/progress.json
DEDUPE_FILE=data/dedupe.json
LOG_FILE=logs/app.log
SEARCH_LOCATIONS_FILE=keywords/vietnam-locations.json
SEARCH_RETRY_LIMIT=2

# 飞书 OpenAPI 配置
# 1. 在飞书开放平台创建企业自建应用
# 2. 开启 bitable 权限并发布版本
# 3. 把 app_id/app_secret/app_token/table_id 填到这里
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token
FEISHU_TABLE_ID=your_table_id

# 飞书字段名，默认和 README 中建议的表头一致
FEISHU_FIELD_NAME=店铺名称
FEISHU_FIELD_CUSTOMER_ID=客户ID
FEISHU_FIELD_PHONE=电话
FEISHU_FIELD_ADDRESS=地址
FEISHU_FIELD_WEBSITE=网站
FEISHU_FIELD_MAPS_URL=Google Maps链接
FEISHU_FIELD_RATING=评分
FEISHU_FIELD_REVIEW_COUNT=评论数
FEISHU_FIELD_KEYWORD=搜索关键词
FEISHU_FIELD_PROVINCE=省市
FEISHU_FIELD_SHOP_SUMMARY=
FEISHU_FIELD_PRODUCT_TAGS=
FEISHU_FIELD_FISHING_TYPE=钓法类型
FEISHU_FIELD_ANALYSIS_SOURCE=分析来源
FEISHU_FIELD_ANALYSIS_CONFIDENCE=分析置信度
FEISHU_FIELD_AI_FLAG=

# AI 增强默认关闭。规则引擎会先完成 90%+ 的标签判断。
AI_ANALYSIS_ENABLED=false
AI_PROVIDER=volcano_engine
AI_BATCH_SIZE=5
AI_CACHE_FILE=data/ai-analysis-cache.json

# 可选：OpenAI-compatible 文本接口。当前默认不启用。
AI_ENDPOINT=
AI_API_KEY=
AI_MODEL=

# 可选备用：Gemini Flash。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta

# 第三层：GPT-4o，仅保留给复杂店铺或图片识别，不参与常规批量文本分析。
VISION_ANALYSIS_ENABLED=false
GPT4O_API_KEY=
GPT4O_MODEL=gpt-4o
GPT4O_ENDPOINT=https://api.openai.com/v1/chat/completions
